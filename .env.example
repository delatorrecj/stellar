# ═══════════════════════════════════════════════
# 🔒 STELLA — ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ═══════════════════════════════════════════════

# ── Stellar Network ──────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ── Identity ─────────────────────────────────
STELLAR_ACCOUNT_ALIAS=my-key
STELLAR_PUBLIC_KEY=<YOUR_PUBLIC_KEY_STARTING_WITH_G>

# ── Contract (fill after deployment) ─────────
CONTRACT_ID=<YOUR_CONTRACT_ID_STARTING_WITH_C>
CONTRACT_WASM_HASH=

# ── Freighter Wallet ─────────────────────────
FREIGHTER_PUBLIC_KEY=<YOUR_FREIGHTER_PUBLIC_KEY>

# ── Frontend (if going for prize pool) ───────
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_CONTRACT_ID=<YOUR_CONTRACT_ID>
VITE_FREIGHTER_PUBLIC_KEY=<YOUR_FREIGHTER_PUBLIC_KEY>
