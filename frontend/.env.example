# 🚀 Stella Frontend Environment Configuration
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Enter the deployed contract ID here
VITE_CONTRACT_ID=

# Enter your Freighter wallet public key here for testing
VITE_FREIGHTER_PUBLIC_KEY=

# Enter your designated Arbitrator wallet public key
VITE_DEFAULT_ARBITRATOR=

# ── Admin Dashboard ──────────────────────────────────────────────
# Password for the admin metrics page (/admin).
# Set this in Vercel environment variables — do NOT commit the real value.
# Local dev fallback: 'stella-admin-dev'
VITE_ADMIN_PASSWORD=

# ── Fee Sponsorship (Gasless Transactions) ───────────────────────
# Testnet keypair that sponsors candidate transaction fees.
# Set this in Vercel environment variables — do NOT commit the real value.
# Fund this account via Friendbot before enabling.
# MAINNET NOTE: Move this to a Vercel Edge Function before going live.
VITE_SPONSOR_SECRET=
